\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Replacing HW--BCP with Kissat's measured BCP rate, while keeping the identical CDCL trajectory, slows the same solver by $2.2$--$15.7\times $. The hardware is doing the work.\relax }}{6}{figure.caption.18}}
\newlabel{fig:counterf}{{6}{6}{Replacing HW--BCP with Kissat's measured BCP rate, while keeping the identical CDCL trajectory, slows the same solver by $2.2$--$15.7\times $. The hardware is doing the work.\relax }{figure.caption.18}{}}
