\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}HW--BCP propagate}{3}{subsection.3.3}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Current HW--BCP architecture. Left: CAM/SRAM array (64 clauses $\times $ 4 literal rows) with per--clause processing logic emitting CONF/UP/DONE; the 2--bit value encoding ($0\tmspace  -\thinmuskip {.1667em}\to \tmspace  -\thinmuskip {.1667em}\mathtt  {00}$, $1\tmspace  -\thinmuskip {.1667em}\to \tmspace  -\thinmuskip {.1667em}\mathtt  {11}$, $U\tmspace  -\thinmuskip {.1667em}\to \tmspace  -\thinmuskip {.1667em}\mathtt  {01}$) lets a single comparator distinguish all three states. Right: per--variable propagate routine; on each trail element it scans the clauses indexing that variable, returns at the first conflict, and enqueues at most one new unit implication.\relax }}{4}{figure.caption.8}}
\newlabel{fig:hwbcp}{{3}{4}{Current HW--BCP architecture. Left: CAM/SRAM array (64 clauses $\times $ 4 literal rows) with per--clause processing logic emitting CONF/UP/DONE; the 2--bit value encoding ($0\!\to \!\mathtt {00}$, $1\!\to \!\mathtt {11}$, $U\!\to \!\mathtt {01}$) lets a single comparator distinguish all three states. Right: per--variable propagate routine; on each trail element it scans the clauses indexing that variable, returns at the first conflict, and enqueues at most one new unit implication.\relax }{figure.caption.8}{}}
